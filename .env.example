# Meeting Intelligence — local overrides
#
# Providers:
#   mock       — default, no key (deterministic rules)
#   ollama     — free local model
#   groq       — free-tier cloud API  https://console.groq.com
#   openrouter — free/cheap cloud API https://openrouter.ai
#   openai     — OpenAI or any OpenAI-compatible endpoint via OPENAI_BASE_URL

LLM_PROVIDER=mock
CONFIDENCE_THRESHOLD=0.75
DATA_DIR=data
OUTPUT_DIR=artifacts/runs
CHECKPOINT_DB=artifacts/checkpoints.sqlite

# --- Groq (free API key) ---
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk-...
# GROQ_MODEL=llama-3.1-8b-instant
# pip install -e ".[llm]"

# --- OpenRouter (free models, e.g. :free suffix) ---
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
# pip install -e ".[llm]"

# --- Ollama (free local) ---
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# pip install -e ".[ollama]"  &&  ollama pull llama3.2

# --- OpenAI ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# pip install -e ".[llm]"

# --- Any other free OpenAI-compatible API ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=<free_key>
# OPENAI_MODEL=<model_id>
# OPENAI_BASE_URL=https://host.example/v1
# pip install -e ".[llm]"
